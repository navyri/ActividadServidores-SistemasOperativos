[Unit]
Description=API actividad servidores
After=network.target

[Service]
User=mary
Group=mary
WorkingDirectory=/home/mary/actividadServidores
ExecStart=/home/mary/miniconda3/envs/fastapi/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
